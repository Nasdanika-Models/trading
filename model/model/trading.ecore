    <eStructuralFeatures xsi:type="ecore:EAttribute" name="outsideRth" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EBoolean"
        defaultValueLiteral="false">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Allow execution outside regular trading hours"/>
