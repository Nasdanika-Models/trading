<?xml version="1.0" encoding="UTF-8"?>
<ecore:EPackage xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:ecore="http://www.eclipse.org/emf/2002/Ecore" name="trading" nsURI="ecore://nasdanika.org/models/trading" nsPrefix="org.nasdanika.models.trading">
  <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
    <details key="documentation" value="Interactive Brokers (IBKR) Trading Model for automated trader agents.&#xA;This model captures the core concepts from IBKR's TWS API and Web API&#xA;for creating trading proposals that can be executed on real or paper accounts."/>
  </eAnnotations>
  <eClassifiers xsi:type="ecore:EEnum" name="SecurityType">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Available security types for trading instruments"/>
    </eAnnotations>
    <eLiterals name="STK" literal="STK">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Stock or ETF"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="OPT" value="1" literal="OPT">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Option"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="FUT" value="2" literal="FUT">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Future"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="FOP" value="3" literal="FOP">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Futures Option"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="CFD" value="4" literal="CFD">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Contract for Difference"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="CASH" value="5" literal="CASH">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Forex pair"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="BOND" value="6" literal="BOND">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Bond"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="WAR" value="7" literal="WAR">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Warrant"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="FUND" value="8" literal="FUND">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Mutual Fund"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="CRYPTO" value="9" literal="CRYPTO">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Cryptocurrency"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="IND" value="10" literal="IND">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Index"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="CMDTY" value="11" literal="CMDTY">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Commodity"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="BAG" value="12" literal="BAG">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Combo/Spread"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="IOPT" value="13" literal="IOPT">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Issuer Option"/>
      </eAnnotations>
    </eLiterals>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EEnum" name="OrderType">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Order types supported by IBKR. See https://www.interactivebrokers.com/campus/ibkr-api-page/order-types/"/>
    </eAnnotations>
    <eLiterals name="MKT" literal="MKT">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Market order - executes immediately at best available price"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="LMT" value="1" literal="LMT">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Limit order - executes at specified price or better"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="STP" value="2" literal="STP">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Stop order - becomes market order when stop price is reached"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="STP_LMT" value="3" literal="STP_LMT">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Stop limit order - becomes limit order when stop price is reached"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="MIT" value="4" literal="MIT">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Market-if-Touched - becomes market order when trigger price is reached"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="LIT" value="5" literal="LIT">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Limit-if-Touched - becomes limit order when trigger price is reached"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="TRAIL" value="6" literal="TRAIL">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Trailing stop order"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="TRAIL_LIMIT" value="7" literal="TRAIL_LIMIT">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Trailing stop limit order"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="REL" value="8" literal="REL">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Relative/Pegged-to-Primary order"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="MOC" value="9" literal="MOC">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Market-on-Close order"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="LOC" value="10" literal="LOC">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Limit-on-Close order"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="MIDPRICE" value="11" literal="MIDPRICE">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Midprice order - pegged to midpoint"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="ADAPTIVE" value="12" literal="ADAPTIVE">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="IB Adaptive algo order"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="VWAP" value="13" literal="VWAP">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Volume Weighted Average Price algo"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="TWAP" value="14" literal="TWAP">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Time Weighted Average Price algo"/>
      </eAnnotations>
    </eLiterals>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EEnum" name="OrderAction">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Side of the order - buy or sell"/>
    </eAnnotations>
    <eLiterals name="BUY" literal="BUY"/>
    <eLiterals name="SELL" value="1" literal="SELL"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EEnum" name="TimeInForce">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Time in Force - how long the order remains active"/>
    </eAnnotations>
    <eLiterals name="DAY" literal="DAY">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Valid for the trading day only"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="GTC" value="1" literal="GTC">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Good-Til-Cancelled - remains active until filled or cancelled"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="IOC" value="2" literal="IOC">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Immediate-or-Cancel - fills immediately or cancels unfilled portion"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="GTD" value="3" literal="GTD">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Good-Til-Date - remains active until specified date"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="OPG" value="4" literal="OPG">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="At-the-Opening - executes at market open"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="FOK" value="5" literal="FOK">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Fill-or-Kill - must be filled entirely immediately or cancelled"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="DTC" value="6" literal="DTC">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Day-Til-Cancelled"/>
      </eAnnotations>
    </eLiterals>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EEnum" name="OptionRight">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Option right - Call or Put"/>
    </eAnnotations>
    <eLiterals name="CALL" literal="C"/>
    <eLiterals name="PUT" value="1" literal="P"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EEnum" name="OrderStatus">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Status of an order in the IBKR system"/>
    </eAnnotations>
    <eLiterals name="PendingSubmit" literal="PendingSubmit">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Order transmitted but not yet confirmed by destination"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="PendingCancel" value="1" literal="PendingCancel">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Cancel request sent but not yet confirmed"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="PreSubmitted" value="2" literal="PreSubmitted">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Simulated order accepted, waiting for trigger"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="Submitted" value="3" literal="Submitted">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Order accepted by the system"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="ApiCancelled" value="4" literal="ApiCancelled">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Cancelled by API client before acknowledgement"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="Cancelled" value="5" literal="Cancelled">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Order cancelled by IB system"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="Filled" value="6" literal="Filled">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Order completely filled"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="Inactive" value="7" literal="Inactive">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Order received but no longer active (rejected or cancelled)"/>
      </eAnnotations>
    </eLiterals>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EEnum" name="ProposalStatus">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Status of a trading proposal from an agent"/>
    </eAnnotations>
    <eLiterals name="DRAFT" literal="DRAFT">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Proposal being created, not ready for review"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="PENDING_REVIEW" value="1" literal="PENDING_REVIEW">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Proposal submitted for human review"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="APPROVED" value="2" literal="APPROVED">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Proposal approved for execution"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="REJECTED" value="3" literal="REJECTED">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Proposal rejected, will not be executed"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="EXECUTING" value="4" literal="EXECUTING">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Proposal is being executed"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="EXECUTED" value="5" literal="EXECUTED">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="All orders in proposal have been executed"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="PARTIALLY_EXECUTED" value="6" literal="PARTIALLY_EXECUTED">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Some orders executed, others pending or failed"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="FAILED" value="7" literal="FAILED">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Execution failed"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="EXPIRED" value="8" literal="EXPIRED">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Proposal expired without being executed"/>
      </eAnnotations>
    </eLiterals>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EEnum" name="AccountType">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Type of trading account"/>
    </eAnnotations>
    <eLiterals name="LIVE" literal="LIVE">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Real money account"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="PAPER" value="1" literal="PAPER">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Paper trading account for practice"/>
      </eAnnotations>
    </eLiterals>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EEnum" name="TriggerMethod">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="How simulated stop orders are triggered"/>
    </eAnnotations>
    <eLiterals name="DEFAULT" literal="DEFAULT">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Default method for instrument"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="DOUBLE_BID_ASK" value="1" literal="DOUBLE_BID_ASK">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Triggered on two consecutive bid/ask prices"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="LAST" value="2" literal="LAST">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Triggered on last traded price"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="DOUBLE_LAST" value="3" literal="DOUBLE_LAST">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Triggered on two consecutive last prices"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="BID_ASK" value="4" literal="BID_ASK">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Triggered on bid/ask price"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="LAST_OR_BID_ASK" value="7" literal="LAST_OR_BID_ASK">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Triggered on last or bid/ask"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="MIDPOINT" value="8" literal="MIDPOINT">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Triggered on midpoint"/>
      </eAnnotations>
    </eLiterals>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Contract">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Represents a tradeable financial instrument in IBKR.&#xA;A Contract uniquely identifies a security for trading, market data, and portfolio queries.&#xA;At minimum, requires either conId+exchange OR symbol+secType+exchange+currency."/>
    </eAnnotations>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="conId" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EInt">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="IBKR's unique contract identifier. Use this to specify an exact contract."/>
      </eAnnotations>
    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="symbol" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="The ticker symbol of the underlying instrument (e.g., AAPL, IBM, EUR)"/>
      </eAnnotations>
    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="secType" eType="#//SecurityType"
        defaultValueLiteral="STK">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="The security type of the instrument"/>
      </eAnnotations>
    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="exchange" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"
        defaultValueLiteral="SMART">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Exchange for routing. SMART enables IB SmartRouting for best execution."/>
      </eAnnotations>
    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="primaryExchange" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Primary listing exchange (e.g., NASDAQ, NYSE). Helps disambiguate contracts."/>
      </eAnnotations>
    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="currency" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"
        defaultValueLiteral="USD">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Currency the contract is traded in (e.g., USD, EUR, GBP)"/>
      </eAnnotations>
    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="localSymbol" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="The local trading symbol on the exchange"/>
      </eAnnotations>
    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="tradingClass" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Trading class of the instrument (important for options)"/>
      </eAnnotations>
    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="lastTradeDateOrContractMonth"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="For derivatives: expiration date (YYYYMMDD) or contract month (YYYYMM)"/>
      </eAnnotations>
    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="strike" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EDouble">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="For options: the strike price"/>
      </eAnnotations>
    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="right" eType="#//OptionRight">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="For options: Call (C) or Put (P)"/>
      </eAnnotations>
    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="multiplier" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="For derivatives: contract multiplier (e.g., 100 for US equity options)"/>
      </eAnnotations>
    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="includeExpired" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EBoolean"
        defaultValueLiteral="false">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Set to true to obtain historical data for expired contracts"/>
      </eAnnotations>
    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EReference" name="comboLegs" upperBound="-1"
        eType="#//ComboLeg" containment="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Combo/Spread legs for BAG security type"/>
      </eAnnotations>
    </eStructuralFeatures>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="ComboLeg">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Represents a leg in a combo/spread order"/>
    </eAnnotations>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="conId" lowerBound="1" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EInt">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Contract ID of this leg"/>
      </eAnnotations>
    </eStructuralFeatures>
